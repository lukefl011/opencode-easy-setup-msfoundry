{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "pri-build",
  "model": "azure/premium-coder",
  "small_model": "azure/premium-mini",
  "provider": {
    "azure": {
      "options": {
        "resourceName": "{env:AZURE_RESOURCE_NAME}"
      },
      "models": {
        "premium-coder": {
          "id": "gpt-5.3-codex",
          "name": "Coder"
        },
        "premium-reasoning": {
          "id": "gpt-5.4",
          "name": "Reasoning"
        },
        "premium-mini": {
          "id": "gpt-5.4-mini",
          "name": "Mini"
        }
      }
    }
  }
}
