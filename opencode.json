{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "model": "azure/coder",
  "small_model": "azure/mini",
  "provider": {
    "azure": {
      "options": {
        "resourceName": "{env:AZURE_RESOURCE_NAME}"
      },
      "models": {
        "coder": {
          "id": "gpt-5.3-codex",
          "name": "Coder"
        },
        "reasoning": {
          "id": "gpt-5.4",
          "name": "Reasoning"
        },
        "mini": {
          "id": "gpt-5.4-mini",
          "name": "Mini"
        }
      }
    }
  }
}
